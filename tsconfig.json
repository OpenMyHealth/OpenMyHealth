{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@contracts": ["./packages/contracts/src/index.ts"],
      "@contracts/*": ["./packages/contracts/src/*"]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "entrypoints/**/*",
    "src/**/*",
    "packages/contracts/src/**/*",
    "packages/relay/src/**/*",
    ".wxt/wxt.d.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "entrypoints/**/*.test.ts",
    "entrypoints/**/*.test.tsx",
    "packages/**/*.test.ts",
    "packages/**/__tests__/**/*",
    "src/test-setup.ts",
    "src/test-utils/**/*"
  ]
}
