{
  "name": "openmyhealth-embedding-bench",
  "private": true,
  "version": "0.0.1",
  "description": "Local browser embedding benchmark using Transformers.js and idb",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "node --test tests/unit/**/*.test.mjs",
    "gen:retrieval-dataset": "node scripts/generate-retrieval-datasets.mjs",
    "eval:retrieval": "node scripts/evaluate-retrieval.mjs --mode both --split all --limit 140",
    "bundle:model": "bash scripts/bundle-embeddinggemma.sh",
    "bench:embed": "node scripts/benchmark-embedding.mjs",
    "bench:embed:real": "node scripts/benchmark-real-phr.mjs",
    "check:no-phr": "bash scripts/check-no-phr.sh"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.2",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "vite": "^7.1.3"
  }
}
