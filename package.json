{
  "name": "openmyhealth",
  "private": false,
  "version": "0.0.0",
  "description": "Chrome extension medical context drafts into AI chatbots",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "wxt -b chrome",
    "dev:e2e": "OMH_E2E=1 wxt -b chrome",
    "dev:firefox": "wxt -b firefox",
    "wxt:build": "wxt build -b chrome",
    "wxt:zip": "wxt zip -b chrome",
    "relay:build": "tsc -p packages/relay/tsconfig.json",
    "relay:start": "pnpm relay:build && node packages/relay/dist/relay/src/server.js",
    "wxt:prepare": "wxt prepare",
    "type-check": "pnpm wxt:prepare && tsc --noEmit && tsc -p packages/contracts/tsconfig.json --noEmit && tsc -p packages/relay/tsconfig.json --noEmit",
    "lint": "eslint --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:relay": "vitest run -c packages/relay/vitest.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:relay",
    "wxt:build:e2e": "OMH_E2E=1 wxt build -b chrome",
    "test:e2e": "pnpm wxt:build:e2e && playwright test -c e2e/playwright.config.ts",
    "test:e2e:headed": "pnpm wxt:build:e2e && playwright test -c e2e/playwright.config.ts --headed",
    "test:e2e:debug": "pnpm wxt:build:e2e && playwright test -c e2e/playwright.config.ts --debug",
    "qa:seed": "node qa/chatbot/seed-fixtures.mjs",
    "qa:chatbot:seed": "pnpm qa:seed",
    "qa:server": "node qa/chatbot/chatbot-server.mjs",
    "qa:chatbot:interactive": "pnpm qa:server",
    "qa:spec": "echo \"Spec-driven QA is manual. Follow docs/qa/spec/README.md with agent-browser + CDP evidence capture.\""
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.33",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.18"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "10.2.3",
      "multimatch>minimatch": "3.1.5"
    }
  }
}
