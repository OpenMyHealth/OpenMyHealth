{
  "name": "openmyhealth",
  "private": false,
  "version": "0.0.0",
  "description": "Chrome extension medical context drafts into AI chatbots",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox",
    "wxt:build": "wxt build -b chrome",
    "wxt:zip": "wxt zip -b chrome",
    "wxt:prepare": "wxt prepare",
    "type-check": "pnpm wxt:prepare && tsc --noEmit",
    "lint": "eslint --max-warnings=0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/chrome": "^0.1.33",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "10.2.1",
      "web-ext-run>minimatch": "5.1.6"
    }
  }
}
