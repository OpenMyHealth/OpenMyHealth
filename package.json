{
  "name": "openmyhealth",
  "private": false,
  "version": "0.1.1",
  "description": "Chrome extension that injects HIRA-based medical context drafts into AI chatbots",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && node scripts/build-dist.mjs && node scripts/copy-static.mjs && node scripts/generate-release-metadata.mjs && node scripts/generate-dist-file-manifest.mjs",
    "validate:dist": "node scripts/validate-dist.mjs",
    "watch": "tsc -p tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "jest --config jest.config.cjs",
    "loop:gates": "bash scripts/run-gates.sh",
    "loop:full": "pnpm loop:gates && pnpm test:visual",
    "loop:planner": "bash scripts/ralph-loop.sh planner",
    "loop:builder": "bash scripts/ralph-loop.sh builder",
    "loop:verifier": "bash scripts/ralph-loop.sh verifier",
    "loop:release": "bash scripts/ralph-loop.sh release",
    "loop:orchestrate": "bash scripts/ralph-orchestrator.sh",
    "release:cut": "bash scripts/release-version.sh",
    "release:verify-checksum": "bash scripts/verify-release-checksum.sh",
    "test:visual": "playwright test",
    "test:e2e:extension": "playwright test -c playwright.extension.config.ts",
    "test:e2e:live": "node scripts/e2e-live-browser-smoke.mjs",
    "qa:preflight": "bash scripts/run-production-readiness.sh"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "jsbn": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.33",
    "@types/jest": "^30.0.0",
    "@types/jsbn": "^1.2.33",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.8.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "10.2.1"
    }
  }
}
