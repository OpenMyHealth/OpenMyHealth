{
  "name": "openchart",
  "private": false,
  "version": "0.1.0",
  "description": "Chrome extension that injects HIRA-based medical context drafts into AI chatbots",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-static.mjs",
    "watch": "tsc -p tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "jest --config jest.config.cjs",
    "loop:gates": "bash scripts/run-gates.sh",
    "loop:planner": "bash scripts/ralph-loop.sh planner",
    "loop:builder": "bash scripts/ralph-loop.sh builder",
    "loop:verifier": "bash scripts/ralph-loop.sh verifier",
    "loop:release": "bash scripts/ralph-loop.sh release",
    "loop:orchestrate": "bash scripts/ralph-orchestrator.sh"
  },
  "dependencies": {
    "dayjs": "^1.11.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/chrome": "^0.1.33",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.8.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
